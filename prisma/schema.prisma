generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String            // add a password field for authentication
  name     String?           // optional name field
  createdAt DateTime @default(now())
}
